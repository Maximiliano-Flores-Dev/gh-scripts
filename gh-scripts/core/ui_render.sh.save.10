#!/bin/bash
# ===========================================================
# MODULE: UI RENDERER (Nerd Font & Theme Adaptive)
# ===========================================================

# DefiniciГіn de Glifos Globales
IC_USER=$(printf '\uf407')   # пҖҮ
IC_THEME=$(printf '\uf042')  # в—җ
IC_LANG=$(printf '\uf1ab')   # пҶ«
IC_BRANCH=$(printf '\uf126') # п„Ұ

mostrar_logo() {
    clear
    local G="\e[38;5;${MY_COL}m"
    local R="\e[0m"
    local B="\e[1m"

    echo -e "${G}                               |_| GLOBAL IDE"
    echo -e "                               ${B}v1.0 RELEASE${R}"
    echo -e "${G}   в–„в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ   в–Ҳ                                  "
    echo -e "${G}  в–Ҳ      в–Ҳ      в–Ҳ"
    echo -e "      в–Ҳ   в–Ҳв–Ҳв–Ҳв–Ҳ   в–Ҳв–„в–Ҳв–Ҳв–Ҳв–„"
    echo -e "      в–Ҳ      в–Ҳ   в–Ҳв–Җ   в–Җв–Ҳ"
    echo -e "       в–Җв–„в–„в–„в–„в–Ҳв–Ҳ   в–Ҳ     в–Ҳ"
    echo -e "             в–Ҳ   в–Ҳ     в–Ҳ"
    echo -e "        в–„в–„в–„в–„в–Җ${R}"
    echo -e "${G}   _____   ____   ____   _  ____   ______   _____  "
    echo -e "  / ____| / __ \ |  _ \ | ||  _ \ |__  __| / ____| "
    echo -e " | (___  | |  |_|| |_) || || |_) |  | |   | (___   "
    echo -e "  \___ \ | |   _ |  _ < | ||  __/   | |    \___ \  "
    echo -e "  ____) || |__| || | \ \| || |      | |    ____) | "
    echo -e " |_____/  \____/ |_|  \_\_||_|      |_|   |_____/  "
    echo -e " =================================================== ${R}"
}

draw_status_bar() {
    local G="\e[38;5;${MY_COL}m"
    local R="\e[0m"
    local B="\e[1m"
    local GH_USER=$(gh api user --jq '.login' 2>/dev/null || echo "OFFLINE")
    
    echo -e "\n ${G}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®"
    printf " ${G}в”Ӯ ${B}${IC_USER} GH:${R} %-20s ${G}в”Ӯ ${B}${IC_THEME}${R} %-3s ${G}в”Ӯ ${B}${IC_LANG}${R} %-3s ${G}в”Ӯ\n" \
           "$GH_USER" "$MY_COL" "$LANG_ID"
    echo -e " ${G}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${R}"
}
