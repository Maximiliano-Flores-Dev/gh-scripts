#!/bin/bash
# ===========================================================
# SETUP: GLOBAL IDE v1.0 (Environment Config)
# ===========================================================

echo -e "\e[32m🛠️  Configurando entorno de Global IDE...\e[0m"

# 1. Crear Estructura de Carpetas
echo "📁 Creando carpetas de módulos..."
mkdir -p core automations templates docs

# 2. Dar Permisos
echo "🔑 Asignando permisos de ejecución..."
chmod +x gh-scripts.sh
chmod +x core/*.sh

# 3. Inicializar Archivos de Preferencia (Si no existen)
CONFIG_FILE="$HOME/.gh_color_pref"
LANG_FILE="$HOME/.gh_lang_pref"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "32" > "$CONFIG_FILE" # Color Verde por defecto
    echo "🎨 Color base configurado: Verde (32)"
fi

if [ ! -f "$LANG_FILE" ]; then
    echo "ES" > "$LANG_FILE" # Idioma Español por defecto
    echo "🌐 Idioma configurado: ES"
fi

# 4. Verificación de GitHub CLI
echo -e "\n\e[34m🔍 Verificando sesión de GitHub...\e[0m"
if gh auth status >/dev/null 2>&1; then
    echo "✅ Sesión de GitHub activa."
else
    echo "❌ No has iniciado sesión en GitHub CLI."
    echo "👉 Ejecuta: 'gh auth login' después de este setup."
fi

echo -e "\n\e[32m==========================================="
echo "✨ SETUP COMPLETADO CON ÉXITO"
echo "🚀 Ejecuta './gh-scripts.sh' para lanzar el IDE"
echo -e "===========================================\e[0m"
